msgstr "此功能仅用于开发，请勿在生产环境中启用。"

#: ../../source/user_guide/env_variables.md:385
msgid "**MAGI_ATTENTION_FFA_CUTEDSL_DEBUG_MODE**"
msgstr "**MAGI_ATTENTION_FFA_CUTEDSL_DEBUG_MODE**"

