msgstr "**MAGI_ATTENTION_PROFILE_MODE**"

#: ../../source/user_guide/env_variables.md:377
msgid "**Used by:** `magi_attention.env.general.is_profile_mode_enable`"
msgstr "**使用方：** `magi_attention.env.general.is_profile_mode_enable`"

