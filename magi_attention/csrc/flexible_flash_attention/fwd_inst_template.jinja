// Runtime contract checks to ensure consistency with compile-time constraints
static inline void _check_runtime_contract(
    const at::Tensor& q,
    std::optional<at::ScalarType> out_type_opt,
    float softcap) {
  TORCH_CHECK(!kCatGQA, "cat_gqa is not supported in fwd, please set cat_gqa to False.");
  TORCH_CHECK(q.scalar_type() == at::kHalf || q.scalar_type() == at::kBFloat16,
              "JIT-FFA only supports fp16/bf16 for compute");
  TORCH_CHECK(q.size(2) == kHeadDim,
              "HeadDim mismatch: compiled=", kHeadDim, ", runtime=", q.size(2));
  TORCH_CHECK(((softcap > 0.f) == kHasSoftcap),
              "softcap mismatch with compiled variant");

  if (out_type_opt.has_value()) {
    at::ScalarType out_ty = out_type_opt.value();
    if constexpr (std::is_same_v<TOut, float>) {
      TORCH_CHECK(out_ty == at::kFloat,
                  "out_type must be float32 for this JIT variant");
    } else if constexpr (std::is_same_v<TOut, cutlass::half_t>) {
      TORCH_CHECK(out_ty == at::kHalf,
                  "out_type must be float16 for this JIT variant");
    } else if constexpr (std::is_same_v<TOut, cutlass::bfloat16_t>) {
      TORCH_CHECK(out_ty == at::kBFloat16,
                  "out_type must be bfloat16 for this JIT variant");
    }
  }
}

// Forward implementation: matches the binding signature (flash_bindings.cpp binds to this symbol)
std::vector<at::Tensor> mha_fwd(
    const at::Tensor& q,
    const at::Tensor& k,
    const at::Tensor& v,
    const std::optional<at::Tensor>& sink_,
    std::optional<at::Tensor>& out_,
    std::optional<at::Tensor>& softmax_lse_,
    std::optional<at::Tensor>& max_logit_,
    std::optional<const at::Tensor>& q_ranges_,
    std::optional<const at::Tensor>& k_ranges_,
    std::optional<const at::Tensor>& attn_type_map_,
    std::optional<int> const max_outer_range_width,
    std::optional<const at::Tensor>& merge_q_ranges_,
    std::optional<const at::Tensor>& qk_map_,
    std::optional<const at::Tensor>& unique_count_,
    std::optional<const at::Tensor>& index_sparse_indices_,
    int const inner_indices_cnt,
    int sparse_k_block_size,
    float const softmax_scale,
    float const softcap,
    std::optional<at::ScalarType> out_type_,
    const std::string& sink_layout_,
    int const sm_margin) {
  _check_runtime_contract(q, out_type_, softcap);

  // Parameter preparation
  auto [params, out, softmax_lse, max_logit] = prepare_mha_fwd<kBlockM, kDeterministic, kDisableAtomic, kPackGQA, kReturnMaxLogits>(
      q, k, v, max_outer_range_width, sink_, out_, softmax_lse_, max_logit_,
      q_ranges_, k_ranges_, attn_type_map_, 
      merge_q_ranges_, qk_map_, unique_count_, 
      index_sparse_indices_, inner_indices_cnt,
      sparse_k_block_size,
      softmax_scale, softcap,
      out_type_, sink_layout_, sm_margin);
  
  if constexpr (kProfileMode)
    MagiEvents::stop("fwd_prepare");

  auto stream = at::cuda::getCurrentCUDAStream().stream();

  // Kernel launch (single variant)
  if constexpr (kProfileMode) 
    MagiEvents::start("fwd_run");
  
  run_mha_fwd_<kArch, kBlockM, kBlockN, TCompute, TOut, kHeadDim, kHasSoftcap, kDisableAtomic, kPackGQA, kPackGQAFactor, kDeterministic, kRangeMerge, kSwapAB, kBlockSparse, kIndexSparse, kIntraWGOverlap, kInnerDirMaxToMin, kMaskMode, kReturnMaxLogits, kFwdProducerRegs, kFwdConsumerRegs, kSparseKBlockSize, kInnerLoadMode, kOuterStoreMode, kProfileMode>(params, stream);
  
  if constexpr (kProfileMode) 
    MagiEvents::stop("fwd_run");

  // Post-processing: 
  // 1. fast zero fill for uncovered regions (to match library interface)
  // 2. correct out and lse with attention sink if required
  if constexpr (kProfileMode)
    MagiEvents::start("fwd_postprocess");
  
  run_flash_fwd_post_process(params, stream);
  
  if constexpr (kProfileMode)
    MagiEvents::stop("fwd_postprocess");

  if (kReturnMaxLogits) {
    return {out, softmax_lse, max_logit.value()};
  } else {
    return {out, softmax_lse};
  }
}

PYBIND11_MODULE(TORCH_EXTENSION_NAME, m) {
  m.def("fwd", &mha_fwd, "Forward (single-variant JIT)");
}
